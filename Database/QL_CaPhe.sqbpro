-- Bảng 1: NhanVien
CREATE TABLE NhanVien (
    MaNV TEXT PRIMARY KEY,
    HoTen TEXT NOT NULL,
    GioiTinh TEXT,
    NgaySinh TEXT,
    ChucVu TEXT,
    LuongCoBan REAL,
    TrangThai TEXT DEFAULT 'Đang làm'
);

-- Bảng 2: TaiKhoan
CREATE TABLE TaiKhoan (
    TenDangNhap TEXT PRIMARY KEY,
    MatKhauHash TEXT NOT NULL,
    Role TEXT NOT NULL,
    MaNV TEXT,
    FOREIGN KEY (MaNV) REFERENCES NhanVien(MaNV) ON DELETE SET NULL
);

-- Bảng 3: CaLam
CREATE TABLE CaLam (
    MaCa INTEGER PRIMARY KEY,
    TenCa TEXT NOT NULL,
    GioBatDau TEXT NOT NULL,
    GioKetThuc TEXT NOT NULL
);

-- Bảng 4: ChamCong
CREATE TABLE ChamCong (
    MaCham INTEGER PRIMARY KEY,
    MaNV TEXT,
    MaCa INTEGER,
    NgayLam TEXT NOT NULL,
    ClockIn TEXT,
    ClockOut TEXT,
    GhiChu TEXT,
    FOREIGN KEY (MaNV) REFERENCES NhanVien(MaNV) ON DELETE SET NULL,
    FOREIGN KEY (MaCa) REFERENCES CaLam(MaCa) ON DELETE SET NULL
);

-- Bảng 5: BangLuong
CREATE TABLE BangLuong (
    MaLuong INTEGER PRIMARY KEY AUTOINCREMENT,
    MaNV TEXT,
    Thang INTEGER NOT NULL,
    Nam INTEGER NOT NULL,
    TongGio REAL,
    LuongThucTe REAL,
    TrangThai TEXT DEFAULT 'Chưa trả',
    FOREIGN KEY (MaNV) REFERENCES NhanVien(MaNV) ON DELETE SET NULL
);

-- Bảng 6: KhachHang
CREATE TABLE KhachHang (
    MaKH TEXT PRIMARY KEY,
    TenKH TEXT NOT NULL,
    SDT TEXT,
    DiemTichLuy INTEGER DEFAULT 0
);

-- Bảng 7: NguyenLieu
CREATE TABLE NguyenLieu (
    MaNL TEXT PRIMARY KEY,
    TenNL TEXT UNIQUE NOT NULL,
    DonVi TEXT NOT NULL,
    SoLuongTon REAL DEFAULT 0
);

-- Bảng 8: SanPham
CREATE TABLE SanPham (
    MaSP TEXT PRIMARY KEY,
    TenSP TEXT NOT NULL,
    LoaiSP TEXT,
    DonGia REAL DEFAULT 0,
    TrangThai TEXT DEFAULT 'Còn bán',
    ImagePath TEXT
);

-- Bảng 9: CongThuc
CREATE TABLE CongThuc (
    MaSP TEXT NOT NULL,
    MaNL TEXT NOT NULL,
    SoLuong REAL NOT NULL,
    PRIMARY KEY (MaSP, MaNL),
    FOREIGN KEY (MaSP) REFERENCES SanPham(MaSP) ON DELETE CASCADE,
    FOREIGN KEY (MaNL) REFERENCES NguyenLieu(MaNL) ON DELETE CASCADE
);

-- Bảng 10: BanAn
CREATE TABLE BanAn (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    tenBan TEXT DEFAULT 'Bàn Mới',
    trangThai TEXT DEFAULT 'Trống'
);

-- Bảng 11: HoaDon
CREATE TABLE HoaDon (
    MaHD TEXT PRIMARY KEY,
    NgayLap TEXT DEFAULT CURRENT_TIMESTAMP,
    MaNV TEXT,
    MaKH TEXT,
    idBan INTEGER NOT NULL,
    TongTien REAL,
    GiamGia REAL,
    ThanhTien REAL,
    TrangThai TEXT DEFAULT 'Đã thanh toán',
    DiemSuDung INTEGER,
    GhiChu TEXT,
    FOREIGN KEY (MaNV) REFERENCES NhanVien(MaNV) ON DELETE SET NULL,
    FOREIGN KEY (MaKH) REFERENCES KhachHang(MaKH) ON DELETE SET NULL,
    FOREIGN KEY (idBan) REFERENCES BanAn(id)
);

-- Bảng 12: ChiTietHoaDon
CREATE TABLE ChiTietHoaDon (
    ChiTietID INTEGER PRIMARY KEY AUTOINCREMENT,
    MaHD TEXT NOT NULL,
    MaSP TEXT NOT NULL,
    SoLuong INTEGER NOT NULL,
    DonGia REAL NOT NULL,
    ThanhTien REAL,
    GhiChu TEXT,
    FOREIGN KEY (MaHD) REFERENCES HoaDon(MaHD) ON DELETE CASCADE,
    FOREIGN KEY (MaSP) REFERENCES SanPham(MaSP)
);

-- Bảng 13: InventoryMovements
CREATE TABLE InventoryMovements (
    MovementID INTEGER PRIMARY KEY AUTOINCREMENT,
    MaNL TEXT,
    ChangeQty REAL NOT NULL,
    MovementType TEXT,
    Timestamp TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (MaNL) REFERENCES NguyenLieu(MaNL) ON DELETE SET NULL
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
